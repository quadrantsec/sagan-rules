alert any any any -> any any (msg:"[EXPERIMENTAL][MSAPI-AZUREAD] Successful User Login From UnManaged/UnTrusted Device To Known AITM Landing Page - Possible AITM"; program:AzureActiveDirectory; json_content:".Operation","UserLoggedIn"; json_content:".AzureActiveDirectoryEventType","1"; json_content:".UserType","0"; json_content:".ApplicationId","4765445b-32c6-49b0-83e6-1d93765276ca"; content:"Login|3a|login"; meta_content:"%sagan%",IsCompliantAndManaged|22 2c 20 22|Value|22 3a 20 22|False|22|,IsCompliantAndManaged|22 2c 22|Value|22 3a 22|False|22|"; meta_content:"%sagan%",UserAuthenticationMethod|22 2c 22|Value|22 3a 22|16|22|,UserAuthenticationMethod|5c 22 2c 5c 22|Value|5c 22 3a 5c 22|16|5c 22|; json_map:"src_ip",".ClientIP"; json_content:!".UserId","_jit@"; json_contains; content:!"|22|TrustType|22 2c 22|Value|22 3a 22|2|22|"; content:!"|22|TrustType|22 2c 22|Value|22 3a 22|1|22|"; content:!"|5c 22|TrustType|5c 22 2c 5c 22|Value|5c 22 3a 5c 22|2|5c 22|"; content:!"|5c 22|TrustType|5c 22 2c 5c 22|Value|5c 22 3a 5c 22|1|5c 22|"; content:!"|22|TrustType|22 2c 20 22|Value|22 3a 20 22|2|22|"; content:!"|22|TrustType|22 2c 20 22|Value|22 3a 20 22|1|22|"; json_map:"src_ip",".ClientIP"; json_map:"username",".UserId"; threshold: type suppress, track by_username&by_src, count 1, seconds 3600; classtype:suspicious-activity; priority:1; sid:99557; rev:1; metadata: createdOn 2026_05_28, updatedOn 2026_05_28;)

alert any any any -> any any (msg:"[EXPERIMENTAL][MSAPI-AZUREAD] Persistence - Suspicious Device Registration - Add Registered Owner"; program:AzureActiveDirectory; json_content:".Operation","Add registered owner to device."; json_content:".ResultStatus","Success"; content:"NewValue"; pcre:"/DESKTOP-[A-Z0-9]{6,8}/i"; within:25; json_map:"src_ip",".xff"; threshold: type suppress, track by_src, count 1, seconds 3600; classtype:suspicious-activity; priority:1; reference:url,attack.mitre.org/techniques/T1098/005/; sid:9870105; rev:1; metadata: createdOn 2026_06_29, updatedOn 2026_06_29;)

