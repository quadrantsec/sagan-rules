alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Admin Audit Hidden New-InboxRule Created"; program:Exchange; json_content:".Operation","New-InboxRule"; content:"|22|Name|22 3a 20 22|Name|22|,|20 22|Value|22 3a 20 22|."; content:!".."; parse_src_ip: 3; classtype:evasion; sid:5017883; rev:1; metadata:created_at 2026_04_15, updated_at 2026_04_15, mitre_tactic_id TA0005, mitre_technique_id T1564.008;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Admin Audit Hidden New-InboxRule Created"; program:Exchange; json_content:".Operation","New-InboxRule"; content:"|22|Name|22 3a 20 22|Name|22|,|20 22|Value|22 3a 20 22|..."; parse_src_ip: 3; classtype:evasion; sid:5017884; rev:1; metadata:created_at 2026_04_15, updated_at 2026_04_15, mitre_tactic_id TA0005, mitre_technique_id T1564.008;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Admin Audit Hidden New-InboxRule Created"; program:Exchange; json_content:".Operation","New-InboxRule"; content:"|22|Name|22 3a 20 22|Name|22|,|20 22|Value|22 3a 20 22 2f 2f 2e 2e|"; parse_src_ip: 3; classtype:evasion; sid:5017885; rev:1; metadata:created_at 2026_04_15, updated_at 2026_04_15, mitre_tactic_id TA0005, mitre_technique_id T1564.008;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Admin Audit Hidden New-InboxRule Created"; program:Exchange; json_content:".Operation","New-InboxRule"; content:"|22|Name|22 3a 20 22|Name|22|,|20 22|Value|22 3a 20 22 20|."; parse_src_ip: 3; classtype:evasion; sid:5017886; rev:1; metadata:created_at 2026_04_15, updated_at 2026_04_15, mitre_tactic_id TA0005, mitre_technique_id T1564.008;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Admin Audit InboxRule Created To Hide Emails"; program:Exchange; json_content: ".Operation", "New-InboxRule"; content:"MoveToFolder"; meta_content:"%sagan%",RSS|20|Feeds,Archive,Conversation|20|History,RSS|20|Subscriptions; parse_src_ip: 3; classtype: evasion; reference:url,https://www.huntress.com/cybersecurity-insights/microsoft-365-hidden-inbox-rule-detection; reference:url,https://redcanary.com/threat-detection-report/techniques/email-hiding-rules/; sid:5017887; rev:1; metadata: createdOn 2026_04_16. updatedOn 2026_04_16, Mitre_TacticID TA0005, Mitre_TacticName Defense Evasion, Mitre_TechniqueID T1564.008, Mitre_TechniqueName Hide_Artifacts;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Mass Email Send Event by User [15/5 Mins]"; program:Exchange; json_content:".Operation","Send"; content:!"ODSP-Notify"; json_map:"username",".UserId"; json_map:"src_ip",".ClientIPAddress"; after: track by_src&by_user, count 15, seconds 300; threshold: type suppress, track by_src&by_username, count 1, seconds 3600; classtype: suspicious-traffic; priority:1; reference:url,https://learn.microsoft.com/en-us/purview/audit-mailboxes; sid:5017890; rev:1; metadata: createdOn 2026_04_16. updatedOn 2026_04_16, Mitre_TacticID TA0008, Mitre_TacticName Lateral_Movement, Mitre_TechniqueID T1534, Mitre_TechniqueName SpearPhishing;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Mass Email Deletion From Sent Folder [100/10 Mins]"; program:Exchange; json_meta_content: ".Operation",SoftDelete,HardDelete,MoveToDeletedItems; json_meta_content: ".ClientInfoString",Client=OWA,Client=OutlookWebApp,Client=WebServices; content:"|22|Path|22 3a 20 22 5c 5c|Sent Items|22|"; content:!"|22|Subject|22 3a 20 22 22|"; json_map:"username",".UserId"; json_map:"src_ip",".ClientIPAddress"; after: track by_src&by_user, count 100, seconds 600; threshold: type suppress, track by_src&by_username, count 1, seconds 3600; classtype: evasion; reference:url,https://learn.microsoft.com/en-us/purview/audit-mailboxes; sid:5017891; rev:1; metadata: createdOn 2026_04_16. updatedOn 2026_04_16, Mitre_TacticID TA0005, Mitre_TacticName Defense_Evasion, Mitre_TechniqueID T1070.008, Mitre_TechniqueName IndicatorRemoval;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Excessive Volume of Mail Items Accessed"; program:Exchange; json_content: ".Operation","MailItemsAccessed"; json_meta_content: ".ClientInfoString",Client=OWA,Client=OutlookWebApp,Client=WebServices; meta_content:"%sagan%",invoice,payment,wire|20|transfer,ACH,remittance,purchase|20|order,PO|20 23|,billing,bank|20|details,account|20|number,urgent,confidential,action|20|required,approval|20|needed,authorization,vendor,contract,agreement,renewal,onboarding,password,reset,login,MFA,2FA,verification|20|code,your|20|account,direct|20|deposit,payroll,w-2,w2,bank|20|change,salary,benefits; meta_nocase; json_map:"username",".UserId"; json_map:"src_ip",".ClientIPAddress"; content:"|22|UserType|22 3a 20|0,"; content:"|22|LogonType|22 3a 20|0,"; after: track by_src&by_user, count 150, seconds 60; threshold: type suppress, track by_src&by_username, count 1, seconds 3600; classtype: collection; reference:url,https://learn.microsoft.com/en-us/purview/audit-mailboxes; sid:5017892; rev:1; metadata: createdOn 2026_04_16. updatedOn 2026_04_16, Mitre_TacticID TA0009, Mitre_TacticName Collection, Mitre_TechniqueID T1114.002, Mitre_TechniqueName EmailCollection;)

alert any any any -> any any (msg:"[MSAPI-EXCHANGE] Inbox Rule Created Or Modified To Hide Campaign-Related Email"; program:Exchange; json_meta_content:".Operation",New-InboxRule,Set-InboxRule; meta_content:"%sagan%",phishing,pishing,email|20|alert,spam,scam,hacked,compromised|20|email; content:"|22|MarkAsRead|22 2c 20 22|Value|22 3a 20 22|True|22|"; classtype:evasion; sid:5017893; rev:1; metadata:created_at 2026_04_16, updated_at 2026_04_16, Mitre_TacticID TA0005, Mitre_TacticName Defense Evasion, Mitre_TechniqueID T1564.008, Mitre_TechniqueName Hide_Artifacts;)


