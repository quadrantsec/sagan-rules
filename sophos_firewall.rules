# rules by "Bryant Smith" <bsmith@quadrantsec.com>
# 02/23/2026

alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] HTTP AntiVirus Module - Virus Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|HTTP/HTTPS|22|"; content:"log_subtype=|22|Virus|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017400; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] HTTP AntiVirus Module - PUA Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|HTTP/HTTPS|22|"; content:"log_subtype=|22|PUA|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017401; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] HTTP AntiVirus Module - Suspicious Domain Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|HTTP/HTTPS|22|"; content:"log_subtype=|22|Clean|22|"; parse_src_ip:1; normalize; bluedot: type url, Malicious,Tor,Proxy; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:suspicious-activity; sid:5017402; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] HTTP AntiVirus Module - Suspicious IP Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|HTTP/HTTPS|22|"; content:"log_subtype=|22|Clean|22|"; parse_src_ip:1; parse_dst_ip:2; normalize; bluedot: type ip_reputation, track by_dst, mdate_effective_period 3 months, Malicious,Tor,Proxy; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:suspicious-activity; sid:5017403; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] FTP AntiVirus Module - Virus Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|FTP|22|"; content:"log_subtype=|22|Virus|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017404; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] FTP AntiVirus Module - Suspicious Domain Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|FTP|22|"; content:"log_subtype=|22|Clean|22|"; parse_src_ip:1; normalize; bluedot: type url, Malicious,Tor,Proxy; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:suspicious-activity; sid:5017405; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] FTP AntiVirus Module - Suspicious IP Detected"; program:sophos; content:"log_type=|22|Anti-Virus|22|"; content:"log_component=|22|FTP|22|"; content:"log_subtype=|22|Clean|22|"; parse_src_ip:1; parse_dst_ip:2; normalize; bluedot: type ip_reputation, track by_dst, mdate_effective_period 3 months, Malicious,Tor,Proxy; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:suspicious-activity; sid:5017406; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Firewall ATP Module - Malware Detected But Not Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|Firewall|22|"; content:"log_subtype=|22|Alert|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017407; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Firewall ATP Module - Malware Detected And Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|Firewall|22|"; content:"log_subtype=|22|Drop|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017408; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] DNS ATP Module - Malware Detected But Not Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|DNS|22|"; content:"log_subtype=|22|Alert|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017409; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] DNS ATP Module - Malware Detected And Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|DNS|22|"; content:"log_subtype=|22|Drop|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017410; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] IPS ATP Module - Malware Detected But Not Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|IPS|22|"; content:"log_subtype=|22|Alert|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017411; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] IPS ATP Module - Malware Detected And Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|IPS|22|"; content:"log_subtype=|22|Drop|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017412; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Web ATP Module - Malware Detected But Not Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|Web|22|"; content:"log_subtype=|22|Alert|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017413; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Web ATP Module - Malware Detected And Blocked"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_component=|22|Web|22|"; content:"log_subtype=|22|Drop|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017414; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] ATP Module - Suspicious Domain Detected"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_subtype=|22|Alert|22|"; parse_src_ip:1; normalize; bluedot: type url, Malicious,Tor,Proxy; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:suspicious-activity; sid:5017415; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] HTTP AntiVirus Module - Suspicious IP Detected"; program:sophos; content:"log_type=|22|ATP|22|"; content:"log_subtype=|22|Alert|22|"; parse_src_ip:1; parse_dst_ip:2; normalize; bluedot: type ip_reputation, track by_dst, mdate_effective_period 3 months, Malicious,Tor,Proxy; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:suspicious-activity; sid:5017416; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Firewall Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|Firewall Authentication|22|"; content:"log_subtype=|22|Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017417; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] My Account Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|My Account Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017418; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Dial-In Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|Dial-In Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017419; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] VPN Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|VPN Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017420; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] SSL VPN Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|SSL VPN Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017421; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] GUI Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|GUI|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017422; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Web Application Firewall Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|Web Application Firewall|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017423; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] CTA Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|CTA|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017424; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Appliance Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|Appliance|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017425; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] External Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|External Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017426; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] VPN Portal Authentication Module - Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_component=|22|VPN Portal Authentication|22|"; content:"status=|22|Failed|22|"; after:track by_src, count 10, seconds 120; threshold:type limit, track by_src, count 1, seconds 14400; xbits:set,SophosFirewall.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017427; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Authentication Module - Login After Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_subtype=|22|Authentication|22|"; content:"status=|22|Successful|22|"; xbits:isset,SophosFirewall.BruteForce,track ip_src; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017428; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Authentication Module - Admin/System Brute Force Attempt"; program:sophos; content:"log_type=|22|Event|22|"; meta_content:"log_subtype=%sagan%",Admin,System; content:"status=|22|Failed|22|"; xbits:set,SophosFirewall.Admin.BruteForce,track ip_src,expire 3600; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017429; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Authentication Module - Admin/System Login After Brute Force"; program:sophos; content:"log_type=|22|Event|22|"; meta_content:"log_subtype=%sagan%",Admin,System; content:"status=|22|Successful|22|"; xbits:isset,SophosFirewall.Admin.BruteForce,track ip_src; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017430; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Authentication Module - Login From Outside Home Country"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_subtype=|22|Authentication|22|"; content:"status=|22|Successful|22|"; country_code:track by_src, isnot $HOME_COUNTRY; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017431; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Authentication Module - Admin/System Login Outside Home Country"; program:sophos; content:"log_type=|22|Event|22|"; meta_content:"log_subtype=%sagan%",Admin,System; content:"status=|22|Successful|22|"; country_code:track by_src, isnot $HOME_COUNTRY; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017432; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Authentication Module - Suspicious IP Login"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_subtype=|22|Authentication|22|"; content:"status=|22|Successful|22|"; bluedot:type ip_reputation, track by_src,none,Malicious,Tor,Proxy; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017433; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] Anti-Spam Module Detection"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_type=|22|Anti-Spam|22|"; meta_content:!"log_subtype=|22|%sagan%|22|",Clean,Allowed,Denied; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017434; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] AntiVirus Email Module Detected Virus"; program:sophos; content:"log_type=|22|Event|22|"; content:"log_type=|22|Anti-virus|22|"; content:"subtype=|22|Virus|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017435; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] IPS Detected A Threat But Not Blocked"; program:sophos; content:"log_type=|22|IDP|22|"; content:"log_subtype=|22|Detect|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017436; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] IPsec Alert Priority Log Detected"; program:sophos; content:"log_type=|22|IPsec|22|"; content:"log_subtype=|22|System|22|"; content:"priority=|22|Alert|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017437; rev:1;)
alert any $HOME_NET any -> $HOME_NET any (msg:"[SOPHOS_FIREWALL] IPsec Critical Priority Log Detected"; program:sophos; content:"log_type=|22|IPsec|22|"; content:"log_subtype=|22|System|22|"; content:"priority=|22|Critical|22|"; parse_src_ip:1; normalize; reference:url,https://docs.sophos.com/nsg/sophos-firewall/21.5/pdf/sf-syslog-guide-21.5.pdf; classtype:trojan-activity; sid:5017438; rev:1;)
